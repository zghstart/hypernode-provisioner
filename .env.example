# ============================================
# HyperNode Provisioner - Environment Variables
# ============================================

# --------------------------------------------
# Backend Configuration
# --------------------------------------------

# Spring Profile
SPRING_PROFILES_ACTIVE=prod

# Database (PostgreSQL)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/hypernode
SPRING_DATASOURCE_USERNAME=hypernode
SPRING_DATASOURCE_PASSWORD=your_strong_password_here

# Redis
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379

# Vault (HashiCorp Vault)
SPRING_VAULT_HOST=localhost
SPRING_VAULT_PORT=8200
SPRING_VAULT_TOKEN=vault-token-placeholder
SPRING_VAULT_BACKEND=vault
SPRING_VAULT_APPROLE_ROLE_ID=your-role-id
SPRING_VAULT_APPROLE_SECRET_ID=your-secret-id

# Server SSH Credentials (encrypted with BCrypt)
SERVER_SSH_USERNAME=deploy
SERVER_SSH_PASSWORD=your_encrypted_password_here
SERVER_SSH_PRIVATE_KEY_PATH=/opt/hypernode/keys/id_rsa

# --------------------------------------------
# Frontend Configuration
# --------------------------------------------

NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_SSE_URL=http://localhost:8080/api/v1/events

# --------------------------------------------
# Docker Configuration
# --------------------------------------------

POSTGRES_DB=hypernode
POSTGRES_USER=hypernode
POSTGRES_PASSWORD=your_strong_password_here

# --------------------------------------------
# Security Settings
# --------------------------------------------

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=86400

# BCrypt Strength (4-31, default: 10)
BCRYPT_STRENGTH=12

# --------------------------------------------
# Monitoring & Logging
# --------------------------------------------

LOG_LEVEL=INFO
LOG_FILE_PATH=/opt/hypernode/logs/app.log

# --------------------------------------------
# Production Deployments
# --------------------------------------------

DEPLOY_HOST=your.server.ip.address
DEPLOY_USER=deploy
DEPLOY_KEY_PATH=/path/to/private/key
